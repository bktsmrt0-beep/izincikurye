{
  "rewrites": [
    { "source": "/ilan/:id", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*\\.(?:js|css|svg|png|jpg|jpeg|webp|ico))",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    }
  ]
}
